 &lt;div class="bm-loading">加载中...&lt;/div>
&lt;/div>
&lt;style>
.bm-loading { text-align: center; padding: 40px; color: var(--secondary-color, #666); }
.bm-error { text-align: center; padding: 40px; color: #e74c3c; }

.bm-folder {
 margin-bottom: 2rem;
 background: var(--card-background, #fff);
 border-radius: 12px;
 padding: 1.5rem;
 box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}
[data-theme="dark"] .bm-folder { background: #1e1e1e; box-shadow: 0 2px 8px rgba(0,0,0,0.3); }

.bm-folder-title {
 font-size: 1.25rem;
 font-weight: 600;
 margin-bottom: 1rem;
 padding-bottom: 0.75rem;
 border-bottom: 2px solid var(--primary-color, #667eea);
 display: flex;
 align-items: center;
 gap: 0.5rem;
}
.bm-folder-title::before { content: "📁"; }

.bm-subfolder {
 margin: 1rem 0;
 padding: 1rem;
 background: var(--background-color, #f8f9fa);
 border-radius: 8px;
}
[data-theme="dark"] .bm-subfolder { background: #2a2a2a; }

.bm-subfolder-title {
 font-size: 1rem;
 font-weight: 500;
 margin-bottom: 0.75rem;
 color: var(--secondary-color, #555);
 display: flex;
 align-items: center;
 gap: 0.4rem;
}
.bm-subfolder-title::before { content: "📂"; font-size: 0.9em; }

.bm-grid {
 display: grid;
 grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
 gap: 0.5rem;
}

.bm-link {
 display: flex;
 align-items: center;
 gap: 0.5rem;
 padding: 0.5rem 0.75rem;
 background: var(--card-background, #fff);
 border: 1px solid var(--border-color, #e5e5e5);
 border-radius: 6px;
 text-decoration: none;
 color: var(--text-color, #333);
 font-size: 0.8rem;
 transition: all 0.2s;
 overflow: hidden;
}
[data-theme="dark"] .bm-link { background: #333; border-color: #444; color: #ddd; }

.bm-link:hover {
 border-color: var(--primary-color, #667eea);
 transform: translateY(-2px);
 box-shadow: 0 4px 12px rgba(102,126,234,0.2);
}

.bm-link img {
 width: 16px;
 height: 16px;
 flex-shrink: 0;
}

.bm-link span {
 overflow: hidden;
 text-overflow: ellipsis;
 white-space: nowrap;
}

@media (max-width: 768px) {
 .bm-grid { grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); }
 .bm-link { padding: 0.4rem 0.5rem; font-size: 0.75rem; }
}
&lt;/style>
&lt;script>
(function() {
 function getFavicon(url) {
 try {
 const domain = new URL(url).hostname;
 return `https://www.google.com/s2/favicons?domain=${domain}&amp;sz=32`;
 } catch { return ''; }
 }

 function renderLink(item) {
 if (!item.href) return '';
 const favicon = getFavicon(item.href);
 return `&lt;a href="${item.href}" target="_blank" rel="noopener" class="bm-link" title="${item.name}">
 ${favicon ? `&lt;img src="${favicon}" alt="" loading="lazy">` : ''}
 &lt;span>${item.name}&lt;/span>
 &lt;/a>`;
 }

 function renderFolder(name, items) {
 let linksHtml = '';
 let subfoldersHtml = '';

 items.forEach(item => {
 if (item.href) {
 linksHtml += renderLink(item);
 } else if (typeof item === 'object') {
 Object.entries(item).forEach(([subName, subItems]) => {
 if (Array.isArray(subItems)) {
 subfoldersHtml += `
 &lt;div class="bm-subfolder">
 &lt;div class="bm-subfolder-title">${subName}&lt;/div>
 &lt;div class="bm-grid">${subItems.map(renderLink).join('')}&lt;/div>
 &lt;/div>`;
 }
 });
 }
 });

 return `&lt;div class="bm-folder">
 &lt;div class="bm-folder-title">${name}&lt;/div>
 ${linksHtml ? `&lt;div class="bm-grid">${linksHtml}&lt;/div>` : ''}
 ${subfoldersHtml}
 &lt;/div>`;
 }

 function render(data) {
 const container = document.getElementById('bookmarks-container');
 if (!data || !Object.keys(data).length) {
 container.innerHTML = '&lt;div class="bm-error">没有书签数据&lt;/div>';
 return;
 }
 container.innerHTML = Object.entries(data).map(([name, items]) =>
 Array.isArray(items) ? renderFolder(name, items) : ''
 ).join('');
 }

 fetch('/bookmarks.json')
 .then(r => r.json())
 .then(render)
 .catch(() => {
 document.getElementById('bookmarks-container').innerHTML =
 '&lt;div class="bm-error">加载失败，请刷新重试&lt;/div>';
 });
})();
&lt;/script></description></item><item><title>C++ 开发碎片笔记</title><link>https://fengchen321.github.io/posts/c++/c++%E5%BC%80%E5%8F%91%E7%A2%8E%E7%89%87%E7%AC%94%E8%AE%B0/</link><pubDate>Wed, 08 Jan 2025 10:00:00 +0800</pubDate><guid>https://fengchen321.github.io/posts/c++/c++%E5%BC%80%E5%8F%91%E7%A2%8E%E7%89%87%E7%AC%94%E8%AE%B0/</guid><category domain="https://fengchen321.github.io/categories/c++/">C++</category><description>&lt;h2 id="c-开发碎片笔记" class="heading-element">&lt;span>C++ 开发碎片笔记&lt;/span>
