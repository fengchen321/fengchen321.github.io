&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-shell" data-lang="shell">&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># nm 查看符号表&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># x /选项 地址 查看各个变量内存信息&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">const char* &lt;span class="nv">str&lt;/span> &lt;span class="o">=&lt;/span> &lt;span class="s2">&amp;#34;test&amp;#34;&lt;/span>&lt;span class="p">;&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">x str &lt;span class="c1"># 默认16进制显示，内存存储内容和“test&amp;#34;相反（小端存储） 0x74736574&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">x /s str &lt;span class="c1"># 直接显示内容 ”test&amp;#34;&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">x /d str &lt;span class="c1"># 十进制显示&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">x /4d str &lt;span class="c1"># 十进制显示，显示宽度为4&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1"># 变量非指针类型，如int， 先p &amp;amp;value_name, 使用x查看&lt;/span>&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
